# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/threed_bot

# --- Groq (LLM generation, free tier) ---
# Ambil API key gratis di https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Embedding & Reranker models ---
EMBEDDING_MODEL_NAME=BAAI/bge-m3
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
EMBEDDING_DEVICE=cpu

# --- Knowledge base ---
KB_FAQ_PATH=data/knowledge_base/02_faq_index_rag.md

# --- Retrieval tuning ---
RETRIEVAL_TOP_K_CANDIDATES=10
RETRIEVAL_TOP_K_FINAL=4
RETRIEVAL_SCORE_THRESHOLD=0.35

# --- Chat ---
HISTORY_MAX_TURNS=8

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- WA Gateway (Node) ---
BACKEND_CHAT_URL=http://localhost:8000/chat
# Optional — both default from BACKEND_CHAT_URL with /chat swapped for the right path
BACKEND_HUMAN_REPLY_URL=http://localhost:8000/human-reply
BACKEND_RESUME_URL=http://localhost:8000/handoff/resume
WA_DEBOUNCE_MS=3000
WA_SESSION_DIR=./.wwebjs_auth
# Admin types this in the customer's chat to resume the bot after handling manually.
# Customer will see this literal text — WhatsApp has no hidden-command channel.
WA_RESUME_KEYWORD=/bot on
